datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  password            String
  role                Role             @default(JOB_SEEKER)
  subscriptionTier    SubscriptionTier @default(FREE)
  freeGenerationsUsed Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  jobSeekerProfile JobSeekerProfile?
  employer         Employer?
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

enum Role {
  JOB_SEEKER
  EMPLOYER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model JobSeekerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  firstName        String
  lastName         String
  otherNames       String?
  gender           String?
  profession       String?
  isSkilledProfessional Boolean @default(false)
  skilledProfession String?
  residenceCountry String?
  residenceState   String?
  residenceCity    String?
  citizenshipCountry String?
  citizenshipState String?
  dateOfBirth      DateTime?
  education        Json?
  certificates     Json?
  professionalCertifications Json?
  experience       Json?
  achievements     Json?
  bio              String?
  resumeUrl        String?
  resumeContent    String?
  profilePicture   String?
  skills           String[]
  autoApplyEnabled Boolean  @default(false)
  autoApplyKeywords String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  applications Application[]
}

model Employer {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  companyName    String
  description    String?
  locationCountry String?
  locationState  String?
  locationCity   String?
  website        String?
  profilePicture String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobs Job[]
}

model Job {
  id          String   @id @default(uuid())
  employerId  String
  employer    Employer @relation(fields: [employerId], references: [id])
  title       String
  description String
  location    String?
  salary      String?
  isRemote    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
}

model Application {
  id               String           @id @default(uuid())
  jobId            String
  job              Job              @relation(fields: [jobId], references: [id])
  jobSeekerId      String
  jobSeekerProfile JobSeekerProfile @relation(fields: [jobSeekerId], references: [id])
  status           ApplicationStatus @default(APPLIED)
  coverLetter      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  REJECTED
  HIRED
  INVITED
  ACCEPTED_OFFER
  DECLINED_OFFER
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content     String
  createdAt   DateTime @default(now())
}
