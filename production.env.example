# MANDATORY PRODUCTION SECRETS
# Set these in AWS Systems Manager Parameter Store or AWS Secrets Manager

# Backend Database
DATABASE_URL=postgresql://postgres:password@database-url:5432/jobhub?schema=public

# Authentication
JWT_SECRET=your_super_secure_jwt_secret

# AI Model Access (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Monetization (Paystack Live Keys)
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
PAYSTACK_SECRET_KEY=sk_live_your_secret_key

# Web Configuration
NEXT_PUBLIC_API_URL=https://api.jobhubai.com
